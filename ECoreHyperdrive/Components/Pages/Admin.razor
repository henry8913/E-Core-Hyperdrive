@page "/admin"
@using ECoreHyperdrive.Models
@using ECoreHyperdrive.Services
@inject CarService CarSrv
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="admin-container">
    <h1 class="brand-title">Controllo Totale Flotta</h1>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success" role="alert">
            @successMessage
        </div>
    }

    <div class="form-card mb-5">
        <h3>Auto nel Database</h3>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Modello</th>
                    <th>0-100 (s)</th>
                    <th>Autonomia (km)</th>
                    <th>Prezzo</th>
                    <th>Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var car in cars)
                {
                    <tr>
                        <td>@car.Brand @car.Model</td>
                        <td>@car.ZeroToHundred</td>
                        <td>@car.RangeKm</td>
                        <td>@car.Price.ToString("N0") €</td>
                        <td>
                            <button @onclick="() => EditCar(car)" class="btn-edit me-2">Modifica</button>
                            <button @onclick="() => DeleteCar(car.Id)" class="btn-delete">Elimina</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="form-card">
        <h3>@(isEditing ? "Modifica Auto" : "Aggiungi Nuovo Prototipo")</h3>
        <EditForm Model="@currentCar" OnValidSubmit="HandleSave" FormName="AdminAddCar">
            <div class="form-group">
                <label>Brand e Modello</label>
                <div class="row">
                    <div class="col"><InputText @bind-Value="currentCar.Brand" class="form-control" placeholder="Brand" /></div>
                    <div class="col"><InputText @bind-Value="currentCar.Model" class="form-control" placeholder="Modello" /></div>
                </div>
            </div>
            
            <div class="row mt-3">
                <div class="col"><label>0-100 (s)</label><InputNumber @bind-Value="currentCar.ZeroToHundred" class="form-control" /></div>
                <div class="col"><label>Autonomia (km)</label><InputNumber @bind-Value="currentCar.RangeKm" class="form-control" /></div>
                <div class="col"><label>Prezzo (€)</label><InputNumber @bind-Value="currentCar.Price" class="form-control" /></div>
            </div>

            <div class="form-group mt-3">
                <label>URL Immagine</label>
                <InputText @bind-Value="currentCar.ImageUrl" class="form-control" />
            </div>

            <div class="mt-4">
                <button type="submit" class="btn-save">@(isEditing ? "� Salva Modifiche" : "Registra nel Database")</button>
                @if (isEditing)
                {
                    <button type="button" class="btn-cancel ms-2" @onclick="ResetForm">Annulla</button>
                }
            </div>
        </EditForm>
    </div>
</div>

@code {
    private List<Supercar> cars = new();
    private Supercar currentCar = new();
    private bool isEditing = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCars();
    }

    private async Task LoadCars()
    {
        try
        {
            cars = await CarSrv.GetInventoryAsync();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore nel caricamento: {ex.Message}";
        }
    }

    private async Task HandleSave()
    {
        try
        {
            if (isEditing)
            {
                await CarSrv.UpdateCarAsync(currentCar);
                successMessage = "Auto modificata con successo!";
            }
            else
            {
                await CarSrv.AddCarAsync(currentCar);
                successMessage = "Nuova auto aggiunta al database!";
            }
            
            ResetForm();
            await LoadCars();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore durante il salvataggio: {ex.Message}";
            successMessage = null;
        }
    }

    private void EditCar(Supercar car)
    {
        // Create a copy to avoid editing the list directly before saving
        currentCar = new Supercar
        {
            Id = car.Id,
            Brand = car.Brand,
            Model = car.Model,
            ZeroToHundred = car.ZeroToHundred,
            Price = car.Price,
            ImageUrl = car.ImageUrl,
            RangeKm = car.RangeKm
        };
        isEditing = true;
        errorMessage = null;
        successMessage = null;
    }

    private async Task DeleteCar(int id)
    {
        try
        {
            await CarSrv.DeleteCarAsync(id);
            await LoadCars();
            successMessage = "Auto eliminata correttamente.";
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Errore durante l'eliminazione: {ex.Message}";
            successMessage = null;
        }
    }

    private void ResetForm()
    {
        currentCar = new();
        isEditing = false;
        // Don't clear messages here so the user sees the result of the action
    }
}